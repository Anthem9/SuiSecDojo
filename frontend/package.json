{
  "name": "suisec-dojo-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "predev": "npm run sync:content",
    "sync:content": "cd .. && scripts/sync-content.sh",
    "build": "tsc --noEmit && vite build",
    "prebuild": "npm run sync:content",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@mysten/dapp-kit": "^1.0.4",
    "@mysten/sui": "^2.16.0",
    "@tanstack/react-query": "^5.100.5",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "jsdom": "^25.0.1",
    "vitest": "^3.2.4"
  }
}
